{
  "ui8kit": {
    "file": "ui8kit.js"
  },
  "ariaMode": "subset",
  "ariaVersion": "0.1.0",
  "patterns": [
    "alert",
    "dialog",
    "sheet"
  ],
  "hooks": {
    "dialog": [
      "data-ui8kit-dialog",
      "data-ui8kit-dialog-open",
      "data-ui8kit-dialog-close",
      "data-ui8kit-dialog-target"
    ],
    "sheet": [
      "data-ui8kit",
      "data-ui8kit-dialog",
      "data-ui8kit-dialog-open",
      "data-ui8kit-dialog-close",
      "data-ui8kit-dialog-target"
    ]
  }
}
