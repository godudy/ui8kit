package example

templ Page() {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>Templ component registry</title>
			<link rel="stylesheet" href="/static/css/app.css"/>
		</head>
		<body class="bg-background text-foreground antialiased">
			@RegistryDemo()
		</body>
	</html>
}
